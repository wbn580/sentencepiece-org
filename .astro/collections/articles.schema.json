{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "section": {
      "type": "string",
      "enum": [
        "concept",
        "math",
        "code",
        "compare",
        "papers"
      ]
    },
    "publishDate": {
      "type": "string"
    },
    "readingTime": {
      "type": "number"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "section",
    "publishDate"
  ]
}