---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: string;
}

const {
  title, description,
  ogImage = '/og-image.png',
  canonicalURL,
  schema,
} = Astro.props;

const SITE_NAME = 'XGBoost · A Reader\'s Encyclopedia';
const BASE_URL = 'https://xgboost.org';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title} — {SITE_NAME}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL || BASE_URL} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:type" content="article" />

<meta name="robots" content="index, follow" />
<meta name="ai" content="allow" />

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />

{schema && <script type="application/ld+json" set:html={schema} />}
