---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · Not Found" description="Page not found.">
  <div class="max-w-3xl mx-auto px-6 py-20 text-center">
    <p class="font-mono text-6xl text-xgb-lime font-bold mb-4">404</p>
    <h1 class="font-mono text-2xl text-xgb-ink font-bold mb-4">Page Not Found</h1>
    <p class="text-xgb-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="inline-block px-4 py-2 border border-xgb-lime text-xgb-lime font-mono text-sm rounded hover:bg-xgb-lime hover:text-white transition-colors no-underline">Back to Home</a>
  </div>
</BaseLayout>
