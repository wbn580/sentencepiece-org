---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const featured = articles.slice(0, 6);

const paths = [
  { slug: 'concept', name: 'Concept', desc: 'Subwords, normalization, vocabulary design, multilingual text, and detokenization.' },
  { slug: 'math', name: 'Math', desc: 'Tokenizer quality, sequence length, fertility, and vocabulary trade-offs.' },
  { slug: 'code', name: 'Code', desc: 'Train, evaluate, and integrate SentencePiece and other tokenizer libraries.' },
  { slug: 'compare', name: 'Compare', desc: 'SentencePiece, BPE, WordPiece, Unigram, tiktoken, and modern alternatives.' },
  { slug: 'papers', name: 'Papers', desc: 'Annotated tokenization research, benchmarks, fairness, and emerging methods.' },
];

const homeSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SentencePiece Guide',
  url: 'https://sentencepiece.org',
  description: 'An independent guide to SentencePiece and modern subword tokenization.',
  inLanguage: 'en',
});
---

<BaseLayout
  title="SentencePiece Guide · Modern Tokenization"
  description="An independent guide to SentencePiece and modern tokenization: concepts, training, evaluation, comparisons, multilingual text, and research."
  schema={homeSchema}
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16 text-center">
    <p class="font-mono text-xs text-xgb-lime uppercase tracking-widest mb-4">Language-Agnostic Tokenization</p>
    <h1 class="font-mono text-4xl md:text-5xl text-xgb-ink font-bold leading-tight mb-6">
      SentencePiece<br/><span class="text-xgb-muted font-normal">A Practical Tokenization Guide</span>
    </h1>
    <p class="max-w-2xl mx-auto text-xgb-muted leading-relaxed">
      A focused, independent resource for language-agnostic tokenization. Understand BPE and Unigram models, train reproducible tokenizers, evaluate quality, and compare modern libraries and algorithms.
    </p>
  </section>

  <!-- Learning paths -->
  <section class="max-w-6xl mx-auto px-6 pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
      {paths.map(p => (
        <a href={`/${p.slug}/`} class="block p-5 border border-gray-200 rounded hover:border-xgb-lime/40 hover:bg-gray-50 transition-colors no-underline group">
          <h2 class="font-mono text-base text-xgb-ink font-bold group-hover:text-xgb-lime transition-colors">{p.name}</h2>
          <p class="text-xs text-xgb-muted mt-1">{p.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <h2 class="font-mono text-lg text-xgb-ink font-bold mb-6">Latest entries</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {featured.map(article => (
        <a href={`/${article.data.section}/${article.id}/`} class="block p-5 border border-gray-200 rounded hover:border-xgb-lime/40 transition-colors no-underline group">
          <span class="text-xs text-xgb-lime font-mono uppercase tracking-wide">{article.data.category}</span>
          <h3 class="font-mono text-base text-xgb-ink font-bold mt-1 mb-2 group-hover:text-xgb-lime transition-colors">{article.data.title}</h3>
          <p class="text-xs text-xgb-muted leading-relaxed">{article.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
